<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    tools:context=".BudgetSettingsActivity">

    <!-- TITLE -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Budget Settings"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginBottom="8dp"/>

    <!-- SMALL DESCRIPTION -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Set your spending limits to control your monthly budget"
        android:textSize="14sp"
        android:textColor="#808080"
        android:layout_marginBottom="25dp"/>

    <!-- MIN BUDGET -->
    <EditText
        android:id="@+id/etMinBudget"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Minimum monthly budget"
        android:background="#EEEEEE"
        android:textColor="#000000"
        android:textColorHint="#808080"
        android:padding="12dp"
        android:layout_marginBottom="12dp"/>

    <!-- MAX BUDGET -->
    <EditText
        android:id="@+id/etMaxBudget"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Maximum monthly spending limit"
        android:background="#EEEEEE"
        android:textColor="#000000"
        android:textColorHint="#808080"
        android:padding="12dp"
        android:layout_marginBottom="25dp"/>

    <!-- SAVE BUTTON -->
    <Button
        android:id="@+id/btnSaveBudget"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Save Budget"
        android:textAllCaps="false"/>

    <Button
        android:id="@+id/btnLogout"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Back"
        android:onClick="back_home"
        android:textColor="#FFFFFF"
        android:backgroundTint="#D32F2F"/>

</LinearLayout>